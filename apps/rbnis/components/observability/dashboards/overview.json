                    "spec": {
                      "editorMode": "code",
                      "expr": "kube_horizontalpodautoscaler_spec_target_metric{namespace=\"rbnis\"} / 100",
                      "instant": false,
                      "legendFormat": "HPA Target",
                      "range": true
                    },
                    "version": "v0"
                  },
                  "refId": "HPA"
