                      "expr": "sum(increase(container_cpu_cfs_throttled_periods_total{job=\"kubelet\", metrics_path=\"/metrics/cadvisor\", namespace=\"rbnis\", container!=\"\"}[$__rate_interval])) by (namespace) /sum(increase(container_cpu_cfs_periods_total{job=\"kubelet\", metrics_path=\"/metrics/cadvisor\", namespace=\"rbnis\", container!=\"\"}[$__rate_interval])) by (namespace)",
